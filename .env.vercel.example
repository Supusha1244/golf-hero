# ============================================================
# VERCEL ENVIRONMENT VARIABLES — copy these into your
# Vercel project settings under Settings → Environment Variables
# ============================================================

# ── Clerk Authentication ─────────────────────────────────────
# Find these in Replit: click the lock icon (Secrets) in the
# left toolbar. Copy CLERK_SECRET_KEY and VITE_CLERK_PUBLISHABLE_KEY.
CLERK_SECRET_KEY=sk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# After your FIRST deploy you will know your Vercel URL.
# Set this to enable the Clerk proxy (recommended for production):
# e.g. https://golf-hero.vercel.app/api/__clerk
VITE_CLERK_PROXY_URL=https://YOUR_VERCEL_URL/api/__clerk

# ── Database (Neon PostgreSQL) ────────────────────────────────
# 1. Go to https://neon.tech and create a free account
# 2. Create a new project → copy the connection string shown
#    (should look like: postgresql://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require)
DATABASE_URL=postgresql://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require

# ── Session Secret ────────────────────────────────────────────
# Generate a random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_random_32_char_string

# ── Node Environment (set automatically by Vercel — no action needed) ──
NODE_ENV=production
